# Copy to .env and fill in values. Never commit .env.

DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=details

# Supabase / managed Postgres often need SSL
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

PORT=5000

# Strong secret in production (defaults to ADMIN_PASSWORD if unset)
# ADMIN_SESSION_SECRET=

# Admin login for dashboard (required)
ADMIN_PASSWORD=bhumitra

# Comma-separated allowed browser origins for CORS (production frontend URL)
# CORS_ORIGIN=https://your-app.vercel.app,http://localhost:3000
